{
    "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "smiling-development-consulting",
  "main": "./dist/_worker.js/index.js",
  "compatibility_date": "2026-03-06",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist"
  },
  "observability": {
    "enabled": true
  }
}