---
export const prerender = true;
import { getCollection } from "astro:content";
import MainLayout from "../../layouts/main.astro";

const projects = await getCollection("projects");
---

<MainLayout
	title="Our Clients - Smiling Dev Consulting"
	description="View case studies and projects we've completed for our satisfied clients."
>
	<div class="container mx-auto px-4 py-12 max-w-4xl">
		<div class="mb-12">
			<h1 class="text-4xl md:text-5xl font-bold mb-4 text-foreground">Our Clients</h1>
			<p class="text-xl text-muted-foreground mb-8">
				We've had the privilege of working with amazing organizations and businesses. Here are some of the projects we've completed.
			</p>
		</div>

		<div class="grid gap-6 md:grid-cols-2">
			{projects.map((project) => (
				<article class="bg-background dark:bg-muted rounded-lg shadow-md hover:shadow-lg transition-shadow duration-300 p-6 border border-border dark:border-border">
					<div class="flex flex-col h-full">
						<div class="flex-grow">
							<h2 class="text-xl font-semibold text-foreground dark:text-foreground mb-3 leading-tight">
								<a 
									href={`/projects/${project.data.slug}`}
									class="hover:text-primary dark:hover:text-primary transition-colors"
								>
									{project.data.title}
								</a>
							</h2>
							
							{project.data.description && (
								<p class="text-muted-foreground dark:text-muted-foreground mb-4 line-clamp-3">
									{project.data.description}
								</p>
							)}
						</div>
						
						<div class="flex items-center justify-between pt-4 border-t border-border dark:border-border">
							<div class="flex items-center text-sm text-muted-foreground dark:text-muted-foreground">
								<span class="inline-block px-3 py-1 bg-primary/10 text-primary rounded-full text-xs font-semibold uppercase tracking-wide">{project.data.status}</span>
							</div>
							
							<div class="flex flex-wrap gap-1 justify-end">
								{project.data.technologies?.slice(0, 2).map((tech) => (
									<span class="inline-block bg-muted dark:bg-muted text-foreground dark:text-foreground text-xs px-2 py-1 rounded">
										{tech}
									</span>
								))}
								{project.data.technologies && project.data.technologies.length > 2 && (
									<span class="text-xs text-muted-foreground dark:text-muted-foreground px-2 py-1">
										+{project.data.technologies.length - 2}
									</span>
								)}
							</div>
						</div>
					</div>
				</article>
			))}
		</div>

		<div class="mt-12 text-center">
			<a 
				href="/projects"
				class="inline-flex items-center gap-2 text-primary hover:text-primary/80 dark:hover:text-primary/80 transition-colors font-medium"
			>
				← View all projects
			</a>
		</div>
	</div>
</MainLayout>
