---
// Proposal content component - displayed only after authentication

const mermaidArchitecture = `graph TD
    Start_Paid((Paid Ads/Social)) --> CF_Landing[ClickFunnels Landing Page]
    Start_Seminar((Live Seminar)) --> QR_Code[QR Code / Direct Link]
    Start_Invite((Group Invite)) --> Invite_Link[Group Invite Link]

    subgraph Importance_Code_App [Importance Code App / Portal]
        Auth_Check{Has Account?}
        Diagnostic[Personality Diagnostic Test]
        Results_Internal[Internal Results Dashboard]
        Admin_Dashboard[Team/Admin Dashboard]
    end

    subgraph Backend_Services [Backend and Marketing]
        Supabase[(Supabase DB and Auth)]
        SMTP_RESEND[Resend Email Service]
        CF_Sales[ClickFunnels Sales/Results Page]
        FB_Pixel[[Facebook Pixel / Conversion API]]
    end

    CF_Landing -- "Pass Email via URL" --> Auth_Check
    QR_Code --> Diagnostic
    Invite_Link --> Diagnostic

    Diagnostic -- "1. Save Results" --> Supabase
    Diagnostic -- "2. Redirect with Params" --> CF_Sales

    CF_Sales -- "3. Fire Conversion" --> FB_Pixel

    Supabase -- "Trigger Confirmation/Results" --> SMTP_RESEND

    Auth_Check -- No --> Diagnostic
    Auth_Check -- Yes --> Results_Internal

    Results_Internal -- "Standard User" --> Results_Internal
    Results_Internal -- "Manager/Admin" --> Admin_Dashboard`;

const mermaidSignupBranching = `flowchart TD
    A[User clicks invite link] --> B{Are seats available?}
    B -- No --> C["Show 'Group is full' message"]
    C --> C1[Notify owner to add seats]
    B -- Yes --> D[User enters email on signup form]
    D --> E{Email in database?}

    E -- "Not found (new user)" --> F[Show full signup: name, email, phone, password]
    F --> G["Create account with role: group_member"]
    G --> H["Add to group — decrement available seats"]
    H --> I["Redirect to test — tagged as group test"]
    I --> J["Post-test: show result + group type-spread"]

    E -- "Found (existing user)" --> K["Welcome back! You already have an account."]
    K --> L["Prompt login — password or magic link"]
    L --> M["Add to group — decrement available seats"]
    M --> N["Prompt: Take the test for Group Name"]
    N --> O["New test instance — context: corporate_group"]
    O --> P[Prior individual tests remain separate]
    P --> J`;

const mermaidFunnel = `flowchart TD
    Entry((Ad Click or Organic CTA)) --> P1

    P1["Page 1: Opt-In — email capture"]
    P1 -. "Pixel: PageView, Lead" .-> Pixels[[Meta/Google Pixels]]
    P1 --> Nurture["Email added to nurture list"]
    P1 --> P2

    P2["Page 2: Value Page — video, testimonials, social proof"]
    P2 -. "Pixel: ViewContent" .-> Pixels
    P2 --> P3

    P3["Page 3: Offer + Stripe Checkout"]
    P3 -. "Pixel: InitiateCheckout" .-> Pixels
    P3 --> PayCheck{Payment outcome?}

    PayCheck -- Success --> Purchase_Pixel["Pixel: Purchase with $ value"]
    Purchase_Pixel --> Webhook["Stripe webhook — auto-create account"]
    Webhook --> P4["Page 4: Thank You — Take your test now"]
    P4 --> Test[Importance Code Test]
    P4 --> P5["Page 5: One-Time Upsell — annual plan, group plan"]

    PayCheck -- Abandoned --> Drip1["1h: You left something behind email"]
    Drip1 --> Drip2["24h: Social proof + reminder"]
    Drip2 --> Drip3["72h: Urgency/scarcity offer"]
    Drip3 --> Retarget["Retargeting: InitiateCheckout NOT Purchase"]`;

const mermaidStripe = `graph TD
    Ads((Paid Ads)) --> CF_Sales[ClickFunnels Sales Page]
    Portal_Upgrade["App: Upgrade Button"] --> Stripe_Session[Stripe Checkout Session]

    CF_Sales -- "Stripe Checkout" --> Stripe_Internal[Stripe Processing]
    Stripe_Session -- "Stripe Checkout" --> Stripe_Internal

    Stripe_Internal -- "Webhook: Payment Success" --> App_Webhook["App: /api/stripe-webhook"]

    subgraph Backend
        App_Webhook -- "Update User Profile" --> Supabase[(Supabase DB)]
        Supabase -- "Grant Access" --> Auth_Logic{Check Permissions}
    end

    Auth_Logic -- Free --> Basic_Dashboard[Basic Results]
    Auth_Logic -- Premium --> Premium_Dashboard[Advanced Analytics / Team Data]

    Stripe_Internal -- "Redirect Back" --> Portal_Success["portal.importancecode.com/success"]`;
---

<!-- Mobile Menu Toggle Button -->
<button
